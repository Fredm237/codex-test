# Copiez en .env et adaptez. Sans clé, tout tourne en mode "mock".

ENV=dev
DEBUG=true

# Infrastructure (laisser vide pour démarrer sans dépendances)
DATABASE_URL=postgresql+asyncpg://filon:filon@postgres:5432/filon
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333

# Routage LLM par tâche : mock | deepseek | kimi | glm
LLM_PROVIDER_DEFAULT=mock
LLM_PROVIDER_REASONING=mock
LLM_PROVIDER_LONG=mock

# Clés (renseignez pour activer le fournisseur correspondant)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

KIMI_API_KEY=
KIMI_MODEL=moonshot-v1-128k

GLM_API_KEY=
GLM_MODEL=glm-4

# Données produits réelles (Google Shopping via SerpApi)
# Sans clé : mode "LLM estimé". Avec clé : vrais produits (photo, prix, lien).
SERPAPI_API_KEY=
SERPAPI_GL=be
SERPAPI_HL=fr
